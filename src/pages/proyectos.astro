<style is:global>
  .proyectos {
    padding: 100px 20px;
    background: white;
  }

  .container-proyectos {
    max-width: 1200px;
    margin: auto;
  }

  /* ENCABEZADO */
  .proyectos-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .proyectos-label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--color-naranja);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 12px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .proyectos-header h2 {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: -0.5px;
    margin: 0 0 16px;
  }

  .proyectos-header h2 em {
    font-style: normal;
    color: var(--color-naranja);
  }

  .proyectos-header p {
    max-width: 560px;
    margin: 0 auto;
    color: #777;
    font-size: 16px;
    line-height: 1.7;
  }

  /* FILTROS */
  .proyectos-filtros {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }

  .filtro {
    padding: 9px 20px;
    border-radius: 50px;
    border: 1.5px solid #e8e8e8;
    background: white;
    color: #555;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: 'Outfit', sans-serif;
    white-space: nowrap;
  }

  .filtro:hover {
    border-color: var(--color-naranja);
    color: var(--color-naranja);
  }

  .filtro.activo {
    background: var(--color-naranja);
    border-color: var(--color-naranja);
    color: white;
  }

  @media (max-width: 640px) {
    .proyectos-filtros {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .filtro {
      text-align: center;
      padding: 10px 12px;
      font-size: 13px;
    }

    .filtro:first-child {
      grid-column: span 2;
    }
  }

  /* GRID */
  .grid-proyectos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* CARD */
  .proyecto {
    border-radius: 14px;
    overflow: hidden;
  }

  .proyecto-img {
    position: relative;
    height: 280px;
    overflow: hidden;
    border-radius: 14px;
    background: #eee;
  }

  .proyecto-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .proyecto:hover .proyecto-img img {
    transform: scale(1.06);
  }

  /* OVERLAY */
  .proyecto-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 6px;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .proyecto:hover .proyecto-overlay {
    opacity: 1;
  }

  .proyecto-tag {
    display: inline-block;
    background: var(--color-naranja);
    color: white;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    width: fit-content;
  }

  .proyecto-overlay h3 {
    color: white;
    font-size: 18px;
    font-weight: 700;
    margin: 0;
  }

  .proyecto-overlay p {
    color: rgba(255,255,255,0.65);
    font-size: 13px;
    margin: 0;
  }

  .proyecto-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: white;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.4);
    padding-bottom: 2px;
    width: fit-content;
    margin-top: 4px;
    transition: border-color 0.25s, color 0.25s;
  }

  .proyecto-btn:hover {
    color: var(--color-naranja);
    border-color: var(--color-naranja);
  }

  /* CTA BOTÓN */
  .proyectos-cta {
    margin-top: 52px;
    display: flex;
    justify-content: center;
  }

  .btn-cotizar {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--color-naranja);
    color: white;
    padding: 14px 30px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
    box-shadow: 0 4px 16px rgba(246, 127, 35, 0.35);
  }

  .btn-cotizar:hover {
    background: #d96a10;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(246, 127, 35, 0.45);
  }

  .btn-cotizar svg { transition: transform 0.25s; }
  .btn-cotizar:hover svg { transform: translateX(4px); }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .grid-proyectos {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .proyectos {
      padding: 64px 16px;
    }

    .grid-proyectos {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    /* Overlay siempre visible en móvil */
    .proyecto-overlay {
      opacity: 1;
    }

    .proyecto-img {
      height: 240px;
    }

    .proyectos-filtros {
      gap: 8px;
    }

    .filtro {
      padding: 8px 14px;
      font-size: 13px;
    }
  }
</style>

