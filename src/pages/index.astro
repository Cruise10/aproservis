---
import Navbar from '../components/Navbar.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	
<Navbar />
<section class="hero">

  <h1>Diseño y Construcción de Proyectos Modernos</h1>

  <p>Especialistas en construcción, arquitectura y remodelaciones.</p>

  <div class="hero-buttons">
	  <a href="#" class="btn-secondary">Ver Proyectos</a>
    <a href="#" class="btn-primary">Solicitar Cotización</a>
  </div>

</section>

<section class="servicios">

<h2>Nuestros Servicios</h2>

<div class="grid">

<div class="card">
<h3>Construcción</h3>
<p>Edificios, casas y obras civiles.</p>
</div>

<div class="card">
<h3>Arquitectura</h3>
<p>Diseños modernos.</p>
</div>

<div class="card">
<h3>Remodelación</h3>
<p>Renovamos espacios.</p>
</div>

</div>

</section>

</Navbar>