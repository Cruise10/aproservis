---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CtaContacto from '../components/CtaContacto.astro';
---

<Layout title="Acerca de — APROSERVIS" description="Conoce quiénes somos, nuestra misión, visión y el equipo detrás de APROSERVIS.">

  <Navbar />

  <!-- HERO BANNER -->
  <section class="page-hero">
    <div class="overlay"></div>
    <div class="page-hero-content">
      <span class="page-label">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--color-naranja)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        QUIÉNES SOMOS
      </span>
      <h1>Más de 10 años construyendo <em>confianza</em></h1>
      <p>APROSERVIS — Añez Proyectos & Servicios. Empresa boliviana comprometida con la excelencia en construcción civil, industrial y mecánica.</p>
    </div>
  </section>

  <!-- QUIÉNES SOMOS + HISTORIA -->
  <section class="sobre-nosotros">
    <div class="container-sobre">
      <div class="sobre-grid">

        <!-- IZQUIERDA: QUIÉNES SOMOS -->
        <div class="sobre-info">

          <span class="section-label">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--color-naranja)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            QUIÉNES SOMOS
          </span>

          <h2>Tu aliado estratégico en <em>construcción</em></h2>

          <p class="sobre-desc">
            APROSERVIS es una empresa proveedora de servicios para las actividades de
            Construcciones Civiles, Industriales y Mecánicas, que manteniendo altos
            niveles de seguridad, excelencia y mejoramiento continuo, se compromete a
            convertirse en aliado de sus clientes.
          </p>

          <p class="sobre-desc">
            Contamos con recursos humanos de amplia experiencia, infraestructura,
            herramientas y equipos especializados aplicados a Construcciones Civiles,
            Industriales y Mecánicas.
          </p>

          <!-- PILARES -->
          <div class="pilares">

            <div class="pilar">
              <div class="pilar-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 7.07 17.07"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <div>
                <h4>Visión</h4>
                <p>Ser empresa líder a nivel nacional con estándares de calidad internacional y compromiso con la excelencia.</p>
              </div>
            </div>

            <div class="pilar">
              <div class="pilar-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              </div>
              <div>
                <h4>Misión</h4>
                <p>Brindar servicios de alta calidad con un equipo calificado, enfocados en la mejora continua y satisfacción del cliente.</p>
              </div>
            </div>

            <div class="pilar">
              <div class="pilar-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h4>Objetivo</h4>
                <p>Cumplir con especificaciones y plazos, mejorando la eficacia del servicio mediante innovación y capacitación permanente.</p>
              </div>
            </div>

          </div>

        </div>

        <!-- DERECHA: HISTORIA + STATS -->
        <div class="sobre-historia">

          <div class="historia-card">
            <span class="section-label">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--color-naranja)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              NUESTRA HISTORIA
            </span>
            <h3>De una visión a una <em>empresa líder</em></h3>
            <p>
              APROSERVIS nació con la visión de convertirse en un aliado estratégico para
              empresas que requieren servicios de construcción civil, industrial y mecánica
              de alta calidad en Bolivia.
            </p>
            <p>
              A lo largo de más de una década, hemos ejecutado más de 200 proyectos en
              todo el país, consolidándonos como referente en el sector gracias a nuestro
              compromiso con la calidad, la seguridad y la mejora continua.
            </p>
            <p>
              Hoy contamos con certificación IBNORCA, equipos para pruebas hasta 20.000 PSI
              y un equipo humano calificado que nos permite asumir proyectos de cualquier
              escala con los más altos estándares.
            </p>

            <!-- TIMELINE -->
            <div class="timeline">
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div>
                  <strong>Fundación</strong>
                  <p>Inicio de operaciones en Santa Cruz, Bolivia con servicios de construcción civil.</p>
                </div>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div>
                  <strong>Expansión Industrial</strong>
                  <p>Incorporación de servicios industriales y mecánicos especializados.</p>
                </div>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div>
                  <strong>Certificación IBNORCA</strong>
                  <p>Autorización para pruebas en tanques de combustible, GLP y sistemas a presión.</p>
                </div>
              </div>
              <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div>
                  <strong>Hoy</strong>
                  <p>+200 proyectos ejecutados. Líderes en construcción civil e ingeniería industrial en Bolivia.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- STATS -->
          <div class="stats-grid">
            <div class="stat-box">
              <strong>+200</strong>
              <span>Proyectos ejecutados</span>
            </div>
            <div class="stat-box">
              <strong>10+</strong>
              <span>Años de experiencia</span>
            </div>
            <div class="stat-box">
              <strong>20.000</strong>
              <span>PSI en pruebas</span>
            </div>
            <div class="stat-box">
              <strong>IBNORCA</strong>
              <span>Certificados</span>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- VALORES -->
  <section class="valores">
    <div class="container-valores">

      <div class="section-header">
        <span class="section-label">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--color-naranja)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          NUESTROS VALORES
        </span>
        <h2>Lo que nos <em>define</em></h2>
        <p>Los principios que guían cada proyecto y cada decisión en APROSERVIS.</p>
      </div>

      <div class="valores-grid">

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Seguridad</h3>
          <p>Cada actividad es evaluada con participación de todos los niveles laborales para eliminar riesgos y garantizar la integridad del personal.</p>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Calidad</h3>
          <p>Planificamos y aplicamos estrategias de mejora continua, garantizando resultados que superan las expectativas de nuestros clientes.</p>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Compromiso</h3>
          <p>Trabajamos con dedicación, competencia y responsabilidad en cada etapa del proyecto, desde el diseño hasta la entrega final.</p>
        </div>

        <div class="valor-card">
          <div class="valor-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3>Innovación</h3>
          <p>Adoptamos técnicas y procesos modernos para reducir defectos, optimizar tiempos y ofrecer soluciones más eficientes.</p>
        </div>

      </div>

    </div>
  </section>

  <!-- EQUIPO -->
  <section class="equipo">
    <div class="container-equipo">

      <div class="section-header">
        <span class="section-label">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--color-naranja)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          NUESTRO EQUIPO
        </span>
        <h2>Las personas detrás de <em>APROSERVIS</em></h2>
        <p>Un equipo multidisciplinario con amplia experiencia en construcción civil, ingeniería industrial y servicios especializados.</p>
      </div>

      <div class="equipo-grid">

        <div class="miembro">
          <div class="miembro-foto">
            <img src="/images/teams/teams1.avif" alt="Gerente General" loading="lazy">
            <div class="miembro-overlay">
              <!-- <a href="#" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </a> -->
            </div>
          </div>
          <div class="miembro-info">
            <h3>Roberto Añez</h3>
            <span>Gerente General</span>
            <p>Fundador de APROSERVIS con más de 15 años de experiencia en construcción civil e industrial.</p>
          </div>
        </div>

        <div class="miembro">
          <div class="miembro-foto">
            <img src="/images/teams/teams2.avif" alt="Director de Ingeniería" loading="lazy">
            <div class="miembro-overlay">
              <!-- <a href="#" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </a> -->
            </div>
          </div>
          <div class="miembro-info">
            <h3>Carlos Méndez</h3>
            <span>Director de Ingeniería</span>
            <p>Ingeniero civil especializado en estructuras metálicas y proyectos industriales de gran escala.</p>
          </div>
        </div>

        <div class="miembro">
          <div class="miembro-foto">
            <img src="/images/teams/teams3.jpg" alt="Jefe de Seguridad Industrial" loading="lazy">
            <div class="miembro-overlay">
              <!-- <a href="#" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </a> -->
            </div>
          </div>
          <div class="miembro-info">
            <h3>Ana Flores</h3>
            <span>Jefa de Seguridad Industrial</span>
            <p>Especialista en normativas de seguridad industrial y certificaciones IBNORCA para sistemas a presión.</p>
          </div>
        </div>

        <div class="miembro">
          <div class="miembro-foto">
            <img src="/images/teams/teams4.avif" alt="Coordinador de Proyectos" loading="lazy">
            <div class="miembro-overlay">
              <!-- <a href="#" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </a> -->
            </div>
          </div>
          <div class="miembro-info">
            <h3>Luis Vargas</h3>
            <span>Coordinador de Proyectos</span>
            <p>Responsable de la planificación y ejecución de proyectos civiles e industriales en todo el país.</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- POLÍTICA DE SEGURIDAD -->
  <section class="politica">
    <div class="container-politica">

      <div class="politica-grid">

        <div class="politica-texto">
          <span class="section-label">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--color-naranja)"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            POLÍTICA DE SEGURIDAD
          </span>
          <h2>La seguridad es <em>nuestra prioridad</em></h2>
          <p>Consideramos la seguridad como un aspecto fundamental del funcionamiento de nuestra empresa. Cada actividad es evaluada con la participación de todos los niveles laborales.</p>
        </div>

        <div class="politica-items">
          <div class="politica-item">
            <div class="check">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p>Ejecutar acciones permanentes para eliminar todos los riesgos que signifiquen amenazas para la seguridad y salud del personal.</p>
          </div>
          <div class="politica-item">
            <div class="check">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p>Establecer e implementar normas y procedimientos para la realización segura de cada trabajo.</p>
          </div>
          <div class="politica-item">
            <div class="check">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p>Capacitar al personal mediante conferencias, cursos y boletines sobre salud ocupacional, seguridad industrial y medio ambiente.</p>
          </div>
          <div class="politica-item">
            <div class="check">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p>Proveer al personal de los elementos y condiciones necesarios para su protección y ejecución segura de actividades.</p>
          </div>
          <div class="politica-item">
            <div class="check">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p>Efectuar evaluaciones periódicas de las capacidades técnicas y condiciones de salud de los trabajadores.</p>
          </div>
        </div>

      </div>

    </div>
  </section>

  <CtaContacto />
  <Footer />

</Layout>

<style is:global>

  /* ── HERO ── */
  .page-hero {
    position: relative;
    height: 380px;
    background: url("/images/cta-footer/subfooter.jpg") center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    margin-top: 72px;
  }

  .page-hero .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
  }

  .page-hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding: 0 20px;
  }

  .page-label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--color-naranja);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 12px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .page-hero-content h1 {
    font-size: clamp(28px, 5vw, 50px);
    font-weight: 800;
    margin: 0 0 16px;
    letter-spacing: -0.5px;
    line-height: 1.15;
  }

  .page-hero-content h1 em {
    font-style: normal;
    color: var(--color-naranja);
  }

  .page-hero-content p {
    font-size: 16px;
    color: rgba(255,255,255,0.78);
    line-height: 1.7;
    margin: 0;
    max-width: 580px;
    margin-inline: auto;
  }

  /* ── SECTION HEADER REUTILIZABLE ── */
  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-header h2 {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: -0.5px;
    margin: 0 0 16px;
  }

  .section-header h2 em {
    font-style: normal;
    color: var(--color-naranja);
  }

  .section-header p {
    max-width: 560px;
    margin: 0 auto;
    color: #777;
    font-size: 16px;
    line-height: 1.7;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--color-naranja);
    font-weight: 700;
    letter-spacing: 2px;
    font-size: 12px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  /* ── SOBRE NOSOTROS ── */
  .sobre-nosotros {
    padding: 100px 20px;
    background: #f5f5f5;
  }

  .container-sobre {
    max-width: 1200px;
    margin: auto;
  }

  .sobre-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .sobre-info h2 {
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: -0.5px;
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .sobre-info h2 em {
    font-style: normal;
    color: var(--color-naranja);
  }

  .sobre-desc {
    font-size: 15px;
    color: #666;
    line-height: 1.8;
    margin: 0 0 20px;
  }

  /* PILARES */
  .pilares {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 32px;
  }

  .pilar {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
    transition: transform 0.25s, box-shadow 0.25s;
  }

  .pilar:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.09);
  }

  .pilar-icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: rgba(246,127,35,0.1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-naranja);
  }

  .pilar h4 {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 5px;
  }

  .pilar p {
    font-size: 13px;
    color: #777;
    line-height: 1.6;
    margin: 0;
  }

  /* HISTORIA */
  .historia-card {
    background: white;
    border-radius: 16px;
    padding: 36px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.07);
    margin-bottom: 20px;
  }

  .historia-card h3 {
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: -0.5px;
    margin: 0 0 18px;
    line-height: 1.25;
  }

  .historia-card h3 em {
    font-style: normal;
    color: var(--color-naranja);
  }

  .historia-card p {
    font-size: 14px;
    color: #666;
    line-height: 1.8;
    margin: 0 0 14px;
  }

  /* TIMELINE */
  .timeline {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 2px solid #f0f0f0;
    padding-left: 24px;
  }

  .timeline-item {
    position: relative;
    padding-bottom: 24px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -31px;
    top: 4px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-naranja);
    border: 2px solid white;
    box-shadow: 0 0 0 2px var(--color-naranja);
  }

  .timeline-item strong {
    font-size: 14px;
    font-weight: 700;
    color: #1a1a1a;
    display: block;
    margin-bottom: 4px;
  }

  .timeline-item p {
    font-size: 13px;
    color: #777;
    line-height: 1.6;
    margin: 0;
  }

  /* STATS */
