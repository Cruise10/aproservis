<header class="header" id="header">
  <div class="container-header">

    <a href="/" class="logo">
      <img src="/images/logo.png" alt="Aproservis Logo">
    </a>

    <nav class="nav" id="nav">
      <ul class="menu">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li><a href="/servicios" class="nav-link">Servicios</a></li>
        <li><a href="/acerca" class="nav-link">Acerca</a></li>
        <li><a href="/proyectos" class="nav-link">Proyectos</a></li>
        <li><a href="/contacto" class="nav-link">Contacto</a></li>
      </ul>
    </nav>

    <div class="header-right">
      <a href="/contacto" class="btn-nav">
        <span>Cotizar</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

      <button class="hamburger" id="hamburger" aria-label="Abrir menú" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    <ul class="mobile-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/servicios">Servicios</a></li>
      <li><a href="/acerca">Acerca</a></li>
      <li><a href="/proyectos">Proyectos</a></li>
      <li><a href="/contacto">Contacto</a></li>
    </ul>
    <a href="/contacto" class="btn-nav-mobile">Cotizar ahora →</a>
  </div>
</header>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap');

  .header {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: 0 20px;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.3s ease;
    font-family: 'Outfit', sans-serif;
  }

  .header.scrolled {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.09);
  }

  .container-header {
    max-width: 1200px;
    margin: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  /* LOGO */
  .logo img {
    height: 64px;
    width: auto;
    display: block;
  }

  /* NAV DESKTOP */
  .nav { display: flex; }

  .menu {
    display: flex;
    list-style: none;
    gap: 8px;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: #333;
    font-weight: 500;
    font-size: 15px;
    padding: 8px 14px;
    border-radius: 8px;
    transition: color 0.25s, background 0.25s;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 14px;
    right: 14px;
    height: 2px;
    background: var(--color-naranja);
    border-radius: 2px;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .nav-link:hover {
    color: var(--color-naranja);
    background: rgba(246, 127, 35, 0.07);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* HEADER RIGHT */
  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* BTN NAV DESKTOP */
  .btn-nav {
    background: var(--color-naranja);
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
    box-shadow: 0 4px 14px rgba(246, 127, 35, 0.35);
  }

  .btn-nav:hover {
    background: #d96a10;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(246, 127, 35, 0.45);
  }

  .btn-nav svg {
    transition: transform 0.25s;
  }

  .btn-nav:hover svg {
    transform: translateX(3px);
  }

  /* HAMBURGER */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .hamburger:hover { background: rgba(0,0,0,0.05); }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #333;
    border-radius: 2px;
    transition: transform 0.35s cubic-bezier(.4,0,.2,1), opacity 0.25s;
    transform-origin: center;
  }

  /* Hamburger → X */
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* MOBILE MENU */
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px 24px;
    border-top: 1px solid rgba(0,0,0,0.07);
    background: white;

    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.4s cubic-bezier(.4,0,.2,1), opacity 0.3s ease, padding 0.3s ease;
  }

  .mobile-menu.open {
    max-height: 400px;
    opacity: 1;
  }

  .mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-links a {
    text-decoration: none;
    color: #333;
    font-weight: 500;
    font-size: 16px;
    padding: 12px 10px;
    border-radius: 8px;
    display: block;
    transition: background 0.2s, color 0.2s;
  }

  .mobile-links a:hover {
    background: rgba(246, 127, 35, 0.08);
    color: var(--color-naranja);
  }

  .btn-nav-mobile {
    margin-top: 12px;
    background: var(--color-naranja);
    color: white;
    padding: 13px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    text-align: center;
    display: block;
    box-shadow: 0 4px 14px rgba(246, 127, 35, 0.35);
    transition: background 0.25s;
  }

  .btn-nav-mobile:hover { background: #d96a10; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .nav { display: none; }
    .btn-nav { display: none; }
    .hamburger { display: flex; }
    .mobile-menu { display: flex; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  const header = document.getElementById('header');

  // Toggle mobile menu
  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    mobileMenu?.classList.toggle('open');
    hamburger?.classList.toggle('open');
    hamburger?.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });

  // Shadow on scroll
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 10);
  });
</script>
