---
import "../assets/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const {
  title = "APROSERVIS — Construcción Civil, Estructuras Metálicas e Ingeniería en Bolivia",
  description = "Empresa especializada en construcción civil, estructuras metálicas, ingeniería de detalle, soldadura para alta presión, sistemas contra incendio y más. Santa Cruz, Bolivia.",
  image = "/images/og-image.jpg",
  url = Astro.url.href,
  type = "website",
} = Astro.props;

const siteName = "APROSERVIS";
const siteUrl = "https://www.aproservis.com";
const canonicalUrl = new URL(url, siteUrl).href;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": siteName,
  "description": description,
  "url": siteUrl,
  "logo": `${siteUrl}/images/logo.png`,
  "image": `${siteUrl}${image}`,
  "telephone": "+59175015677",
  "email": "info@aproservis.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Paragua 2do Anillo, Calle los Tucanes #2439",
    "addressLocality": "Santa Cruz de la Sierra",
    "addressRegion": "Santa Cruz",
    "addressCountry": "BO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -17.7633,
    "longitude": -63.1752
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:00",
      "closes": "12:00"
    }
  ],
  "sameAs": [
    "https://www.facebook.com/share/18cu6Fjmix/",
    "https://www.linkedin.com/company/aproservis"
  ],
  "priceRange": "$$",
  "serviceArea": {
    "@type": "Country",
    "name": "Bolivia"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios APROSERVIS",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Construcción Civil" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Estructuras Metálicas" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ingeniería Básica y de Detalle" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Soldadura para Alta Presión" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pintado Industrial" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sistemas Contra Incendio" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pruebas Hidrostáticas e Hidráulicas" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Provisión de Servicios" } }
    ]
  }
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ═══ FAVICON ═══ -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- ═══ SEO BÁSICO ═══ -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <!-- ═══ KEYWORDS estos son las palabras claves para la busqueda ═══ -->
    <meta name="keywords" content="construcción civil Bolivia, estructuras metálicas Santa Cruz, ingeniería de detalle, soldadura alta presión, sistemas contra incendio, pruebas hidrostáticas, pintado industrial, APROSERVIS, empresa constructora Bolivia" />

    <!-- ═══ GEOLOCALIZACIÓN ═══ -->
    <meta name="geo.region" content="BO-S" />
    <meta name="geo.placename" content="Santa Cruz de la Sierra" />
    <meta name="geo.position" content="-17.7633;-63.1752" />
    <meta name="ICBM" content="-17.7633, -63.1752" />

    <!-- ═══ OPEN GRAPH (Facebook, WhatsApp) ═══ -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_BO" />

    <!-- ═══ TWITTER CARD ═══ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- ═══ TEMA Y COLORES ═══ -->
    <meta name="theme-color" content="#F67F23" />
    <meta name="msapplication-TileColor" content="#F67F23" />

    <!-- ═══ FUENTES ═══ -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- ═══ ICONOS ═══ -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    </noscript>

    <!-- ═══ JSON-LD STRUCTURED DATA ═══ -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>